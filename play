#!/usr/bin/env bash
# Launcher for 20EQ — points harn at the warm llama.cpp server on :8001.
set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"
HARN_REPO="${HARN_REPO:-$HOME/projects/harn}"

export LOCAL_LLM_BASE_URL="${LOCAL_LLM_BASE_URL:-http://localhost:8001}"

# Pre-flight: make sure something OpenAI-compat is actually listening.
if ! curl -fsS "${LOCAL_LLM_BASE_URL}/v1/models" >/dev/null 2>&1; then
  echo "warning: nothing answering at ${LOCAL_LLM_BASE_URL}/v1/models" >&2
  echo "         start your llama.cpp server (or override LOCAL_LLM_BASE_URL)." >&2
  exit 1
fi

cd "$HARN_REPO"

# Pin a stable target dir under this project. Harn's repo `.cargo/config.toml`
# points target-dir at /tmp/harn-devsetup-<pid>/, which gets reaped between
# shells — so without this override every launch silently rebuilds harn
# from scratch and looks like the chat box is hanging.
export CARGO_TARGET_DIR="$HERE/.harn-target"
HARN_BIN="$CARGO_TARGET_DIR/debug/harn"

# Build loud (so first-run compile progress is visible) only if the binary
# is missing or older than the harn sources. Otherwise exec the cached
# binary directly so the chat box launches instantly.
if [[ ! -x "$HARN_BIN" ]] || [[ -n "$(find "$HARN_REPO/crates" -name '*.rs' -newer "$HARN_BIN" -print -quit 2>/dev/null)" ]]; then
  echo "(building harn — first run or harn sources changed; this can take a few minutes...)" >&2
  cargo build --bin harn
fi

exec "$HARN_BIN" run "$HERE/20eq.harn"
