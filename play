#!/usr/bin/env bash
# Launcher for 20EQ. Runs the Harn toolchain (expected on PATH from
# `cargo install harn-cli`) against a local OpenAI-compatible chat server.
set -euo pipefail

HERE="$(cd "$(dirname "$0")" && pwd)"

# Locate harn. Honor $HARN_BIN for hackers running a local source build.
HARN_BIN="${HARN_BIN:-$(command -v harn || true)}"
if [[ -z "$HARN_BIN" ]]; then
  cat >&2 <<'EOF'
20eq: the `harn` binary is not on PATH.

Install Harn from crates.io:

    cargo install harn-cli

This puts a `harn` binary in ~/.cargo/bin/. Then re-run ./play.

(If you have a local Harn source build, point HARN_BIN at it instead:
    HARN_BIN=~/projects/harn/target/debug/harn ./play )
EOF
  exit 127
fi

export LOCAL_LLM_BASE_URL="${LOCAL_LLM_BASE_URL:-http://localhost:8001}"

# Pre-flight: make sure something OpenAI-compat is actually listening.
if ! curl -fsS "${LOCAL_LLM_BASE_URL}/v1/models" >/dev/null 2>&1; then
  echo "20eq: nothing answering at ${LOCAL_LLM_BASE_URL}/v1/models" >&2
  echo "      start your local LLM server, or override LOCAL_LLM_BASE_URL." >&2
  exit 1
fi

exec "$HARN_BIN" run "$HERE/20eq.harn"
