import { agent_private_text_filter } from "std/agent/stream"
import { model_from_env, parse_model_id } from "std/config"

pub type HexCallOverrides = {messages?: list, temperature?: float, max_tokens?: int}

pub type HexCallOptions = {
  provider: string,
  model: string,
  thinking: bool,
  messages?: list,
  temperature?: float,
  max_tokens?: int,
}

pub const MAX_TURNS = 20

pub const SECRET_OPEN = "<secret>"

pub const SECRET_CLOSE = "</secret>"

pub const DEFAULT_MODEL = "local:qwen3.6-35b-a3b-ud-q4-k-xl"

pub fn hex_options(overrides: HexCallOverrides = {}) -> HexCallOptions {
  const route = parse_model_id(model_from_env("TWENTY_EQ_MODEL", DEFAULT_MODEL))
  return {provider: route.provider, model: route.model, thinking: false} + overrides
}

pub fn strip_secret(text: string) -> string {
  return trim(agent_private_text_filter(text, {open_tag: SECRET_OPEN, close_tag: SECRET_CLOSE}))
}

pub fn blank_rebuke(turn: int) -> string {
  const lines = [
    "nice try. the candle does not count silence.",
    "blank offering rejected. put a thought in the bowl.",
    "the void heard that. it was unimpressed.",
    "nope. ellipses are my job, not yours.",
    "the question stays put until you feed it words.",
  ]
  return lines[turn % len(lines)] ?? ""
}

pub fn typing_hint(turn: int) -> string {
  const lines = [
    "the candle leans toward the screen",
    "something under the keys is listening",
    "hex is rummaging around in the static",
    "the cursor holds its breath",
    "the void is chewing on that",
  ]
  return lines[turn % len(lines)] ?? ""
}

pub fn is_exit_command(text: string) -> bool {
  return text == "/quit" || text == "/exit"
}

pub fn turn_label(turn: int) -> string {
  return "you (${turn + 1}/${MAX_TURNS}) > "
}
